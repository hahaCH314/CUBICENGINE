# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# build & temp
/dist/
/dist-electron/
/dist-exe/
/scratch/
/.vscode/

# MMC project archives to prevent AI context pollution
/plans_archive/
/docs/HANDOVER_ARCHIVE.md


# local dev server logs
dev_ps.log
repro_dev.log
*_dev.log

# 使い捨てのデバッグ/確認スクリプト（git状態・typecheck・履歴を調べる類い。
# 繰り返し生成されるので追跡しない＝コミット事故＆Source Controlのノイズを防ぐ）
/check.js
/git_check.js
/find_history.js
